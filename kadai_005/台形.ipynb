        "top_side = 10\n",
        "bottom_side = 20\n",
        "height = 5\n",
        "\n",
        "#公式：台形の面積＝(上辺＋下辺)×高さ÷２\n",
        "area = (top_side + bottom_side) * height / 2\n",
        "\n",
        "print(f\"{int(area)}cm²\")"
      ]
